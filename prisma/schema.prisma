generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id           String   @id @default(uuid())
  name         String?
  email        String?  @unique
  bio          String?
  saltBase64   String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shadowInteractions  ShadowInteraction[] @relation("SourceProfile")
  receivedInteractions ShadowInteraction[] @relation("TargetProfile")
  channels            Channel[]
  dataSources         DataSource[]
}

model DataSource {
  id              String   @id @default(uuid())
  platform        String   
  isConnected     Boolean  @default(true)
  syncStatus      String   @default("IDLE")
  lastSync        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // CETTE LIGNE EST LA CLÉ : Elle crée l'index unique composé attendu par l'API
  @@unique([profileId, platform])
}

model ShadowInteraction {
  id                 String   @id @default(uuid())
  timestamp          DateTime @default(now())
  type               String?  
  status             String?  
  compatibilityScore Float?   
  metadata           Json?    
  
  profileId          String
  profile            Profile  @relation("SourceProfile", fields: [profileId], references: [id], onDelete: Cascade)

  targetProfileId    String?
  targetProfile      Profile? @relation("TargetProfile", fields: [targetProfileId], references: [id])
}

model Channel {
  id        String   @id @default(uuid())
  topic     String?
  createdAt DateTime @default(now())
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])
}