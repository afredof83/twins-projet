// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- MODÈLE PRINCIPAL : PROFIL ---
model Profile {
  id           String   @id @default(uuid())
  name         String?
  email        String?  @unique
  bio          String?
  
  // Champs d'Authentification (Fix erreur précédente)
  saltBase64   String?
  passwordHash String?
  
  // Métadonnées système
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  // 1. Les interactions lancées par ce profil
  shadowInteractions ShadowInteraction[] @relation("SourceProfile")
  
  // 2. Les interactions reçues par ce profil (Optionnel mais recommandé)
  receivedInteractions ShadowInteraction[] @relation("TargetProfile")
  
  // 3. Les channels de discussion
  channels     Channel[]
}

// --- MODÈLE SHADOW INTERACTION (Fix erreur actuelle) ---
model ShadowInteraction {
  id                 String   @id @default(uuid())
  timestamp          DateTime @default(now())
  
  // Champs techniques demandés par votre code (route.ts)
  type               String?  // ex: "SCAN", "MATCH", "PING"
  status             String?  // ex: "PENDING", "ACCEPTED"
  compatibilityScore Float?   // Score de 0 à 100
  metadata           Json?    // Pour stocker des infos flexibles (JSON)
  
  // Relation : Qui a lancé l'action ?
  profileId          String
  profile            Profile  @relation("SourceProfile", fields: [profileId], references: [id], onDelete: Cascade)

  // Relation : Qui est la cible ? (targetProfileId)
  targetProfileId    String?
  targetProfile      Profile? @relation("TargetProfile", fields: [targetProfileId], references: [id])
}

// --- MODÈLE CHANNEL (Pour le Dashboard) ---
model Channel {
  id        String   @id @default(uuid())
  topic     String?
  createdAt DateTime @default(now())
  
  // Propriétaire du channel
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])
}